<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VERITAS — Deepfake Detection</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne+Mono&family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet">
    <!-- External CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <a href="subSystem.html">second chance</a>

<div class="wrapper">

    <!-- HEADER -->
    <header class="header">
        <div>
            <div class="logo">VERI<span>TAS</span></div>
            <div class="tagline">Forensic Image Analysis System</div>
        </div>
        <div class="badge">v2.4.1 · NEURAL ENGINE</div>
    </header>

    <!-- UPLOAD CARD -->
    <div class="upload-card" id="uploadCard">
        <div class="card-label">INPUT CHANNEL — SUBMIT IMAGE FOR ANALYSIS</div>
        <form id="analysisForm" action="/upload" method="post" enctype="multipart/form-data">
            <div class="drop-zone" id="dropZone">
                <div class="corner-br"></div>
                <div class="corner-bl"></div>

                <div class="file-preview" id="filePreview">
                    <img id="previewImg" src="" alt="Preview">
                    <div class="file-name" id="fileName"></div>
                </div>

                <svg class="drop-icon" id="dropIcon" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="1" y="1" width="58" height="58" rx="3" stroke="rgba(0,229,255,0.4)" stroke-width="1.5" stroke-dasharray="6 4"/>
                    <path d="M30 20v14M30 20l-5 5M30 20l5 5" stroke="rgba(0,229,255,0.7)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M18 38c0 0 2-4 12-4s12 4 12 4" stroke="rgba(0,229,255,0.3)" stroke-width="1.5" stroke-linecap="round"/>
                    <circle cx="30" cy="30" r="16" stroke="rgba(0,229,255,0.1)" stroke-width="1"/>
                </svg>

                <div class="drop-title" id="dropTitle">Drop image here or click to browse</div>
                <div class="drop-sub">JPG, JPEG, PNG · Max 10 MB</div>

                <input type="file" name="image" id="fileInput" accept=".jpg,.jpeg,.png" required>
                <button type="submit" class="btn-analyze" id="analyzeBtn">Run Analysis</button>
            </div>
        </form>
        <div class="scanning-bar" id="scanBar"></div>
    </div>

    <!-- RESULT PANEL (populated by JS) -->
    <div class="result-panel" id="resultPanel">
        <div class="result-card" id="resultCard">
            <div class="result-header">
                <div>
                    <div class="verdict-label" id="verdictLabel">ANALYSIS COMPLETE</div>
                    <div class="verdict-text" id="verdictText"></div>
                </div>
                <div class="verdict-icon" id="verdictIcon"></div>
            </div>
            <div class="result-body">
                <div class="confidence-row">
                    <div class="conf-label">CONFIDENCE</div>
                    <div class="conf-track"><div class="conf-fill" id="confFill" style="width:0%"></div></div>
                    <div class="conf-pct" id="confPct">—</div>
                </div>
                <div class="metrics-grid">
                    <div class="metric">
                        <div class="metric-val" id="metricConf">—</div>
                        <div class="metric-key">CONFIDENCE</div>
                    </div>
                    <div class="metric">
                        <div class="metric-val" id="metricVerdict">—</div>
                        <div class="metric-key">VERDICT</div>
                    </div>
                    <div class="metric">
                        <div class="metric-val" id="metricModel">CNN v4</div>
                        <div class="metric-key">MODEL</div>
                    </div>
                </div>
                <div class="heatmap-section" id="heatmapSection" style="display:none">
                    <div class="heatmap-title">SALIENCY HEATMAP</div>
                    <img class="heatmap-img" id="heatmapImg" src="" alt="Explanation heatmap">
                </div>
                <div class="error-msg" id="errorMsg" style="display:none"></div>
            </div>
        </div>
    </div>

    <!-- INFO ROW -->
    <div class="info-row">
        <div class="info-chip">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
                <path d="M6 5v4M6 4h.01" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
            Images processed locally
        </div>
        <div class="info-chip">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M10 4L6 2 2 4v3c0 2 2 3 4 3s4-1 4-3V4z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
            </svg>
            Encrypted transit
        </div>
        <div class="info-chip">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M6 1v2M6 9v2M1 6h2M9 6h2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                <circle cx="6" cy="6" r="2.5" stroke="currentColor" stroke-width="1.2"/>
            </svg>
            Neural engine active
        </div>
    </div>

</div>

    <!-- External JavaScript -->
    <script src="/js/main.js"></script>

    <!-- EJS injection: call renderResult if result exists -->
<% if (result) { %>
    <div id="server-result" data-result='<%- JSON.stringify(result) %>' style="display: none;"></div>
<% } %>

</body>
</html>